# Python bytecode/cache
**/__pycache__/
**/*.pyc
**/.pytest_cache/

# Temporäre Analyse-/Debug-Dateien
_temp_*

# Claude Code interne Dateien
.claude/

# DB credentials (nie committen!)
**/db_config.php

# Test reports
test-results/*.xml

# Zugangsdaten
.htpasswd
.env
.env.*
!.env.example

# Core-Konfigurationsdateien (werden via Deploy-API verwaltet)
core/

maps/core/
maps/public/config/
maps/public/guis/
maps-dev/core/
maps-dev/public/config/
maps-dev/public/guis/

# Build-Artefakte (minifizierte JS) — DEV-Quelle liegt in maps-dev/tnet/js/, PROD-Quellstand in maps/tnet/js-src/
maps-dev/tnet/js-stage/*.js
maps-dev/tnet/js-stage/mobile/*.js
maps-dev/tnet/js-stage/tnet-prod-*.js
maps-dev/tnet/js-stage/mobile/tnet-prod-*.js
maps/tnet/js/*.js
maps/tnet/js/mobile/*.js
maps/tnet/js/tnet-prod-*.js
maps/tnet/js/mobile/tnet-prod-*.js

# Lokaler Upload-State (mtime/sha256-Tracking)
_scripts/deployment/deployengine/upload_state.json
_scripts/deployment/deployengine/upload_state.*.json
_scripts/build/build_state.*.json
_scripts/tools/*.jar

# Lokale Arbeits- und Cookie-Artefakte
edit/
geohost/
redirect-cookies.txt