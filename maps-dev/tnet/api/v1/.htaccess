# TNET API - Clean URLs (ohne .php Endung)
# Platziert in v1/ damit die Regeln direkt greifen
#
# Ermöglicht Aufrufe wie:
#   /maps/tnet/api/v1/layers?group=marco
# statt:
#   /maps/tnet/api/v1/layers.php?group=marco

# === GZIP-Kompression für JSON-Antworten ===
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/plain
</IfModule>

# === ZUGRIFFSCHUTZ ===
# Admin-Seiten werden per Cookie-Auth in PHP geschützt (AdminAuth.php).
# HTML-Admin-Seiten werden über admin-gate.php geroutet.

Options +FollowSymLinks -MultiViews
RewriteEngine On

# Admin-HTML-Seiten → PHP-Gate (Cookie-Auth)
RewriteRule ^(slm|ags-import|tree-builder|dev-test|tree-test)\.html$ admin-gate.php?page=$1 [L,QSA]

# Wenn die angeforderte Datei/Ordner existiert → nichts tun
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Clean URLs: name → name.php
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.php [L,QSA]
