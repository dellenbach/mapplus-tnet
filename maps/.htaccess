<FilesMatch "\.(conf)$">
Order Allow,Deny
Deny from all
</FilesMatch>

RewriteEngine on

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# SPEZIELLE REGELN ZUERST (höchste Priorität)

# Hole den urspruenglichen Host aus dem Forwarded Header für nw_nutzungsplanung 
RewriteCond %{HTTP:X-Forwarded-Host} ^(.+)$
# RewriteRule ^nw_nutzungsplanung/?$ https://%1/maps/?layers=grundnutzung|nw_kbs_DEF|nw_nutzungsplanung_DEF_grundnutzung [R=302,L,QSA]
# Spezielle Playground/Intranet Regeln
RewriteRule ^pg1$ index.php?group=playground1 [QSA,L]
RewriteRule ^pg2$ index.php?group=playground2 [QSA,L]
RewriteRule ^intranet$ index.php?group=intranet [QSA,L]
RewriteRule ^marco$ index_oidc.php?group=marco [QSA,L]

# CATCH-ALL: Alle anderen /maps/xxx URLs -> Interner Rewrite zu index.php mit bookmark Parameter
# Ausnahmen werden bereits ueber REQUEST_FILENAME und das Segment-Muster abgefangen.
# Kartenansichten (Schema v2) werden via Query-String uebergeben: /{bookmark}?view={viewId}
# (Path-Style /{bookmark}/{view} bewusst NICHT genutzt: relative URLs im HTML/JS wuerden
#  durch das zweite Pfad-Segment kaputtgehen.)
RewriteRule ^([a-zA-Z0-9_-]+)$ index.php?bookmark=$1 [QSA,L]


RewriteEngine On
RewriteCond %{QUERY_STRING} LAYERS=show:
RewriteRule ^agsproxy\.php$ - [R=204,L]
