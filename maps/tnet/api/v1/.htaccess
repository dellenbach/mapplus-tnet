# TNET API - Clean URLs (ohne .php Endung)
# Platziert in v1/ damit die Regeln direkt greifen
#
# Ermöglicht Aufrufe wie:
#   /maps/tnet/api/v1/layers?group=marco
# statt:
#   /maps/tnet/api/v1/layers.php?group=marco

# === GZIP-Kompression für JSON-Antworten ===
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/plain
</IfModule>

# === IP-WHITELIST (Apache 2.4) ===
# Erlaubte IPs für Admin-Zugriff. Anpassen bei Standortwechsel / VPN.
#   - 127.0.0.1 / ::1       = Localhost (Server-intern)
#   - 193.135.153.250        = nwow.mapplus.ch (Server selbst)
#   - 193.135.153.10         = Trigonet Server
#   - 84.241.67.175          = Büro Trigonet
#   - 10.10.5.36             = Internes Netz
#   - 10.203.18.133          = Internes Netz
#   - 10.203.*.*             = Internes Subnetz
# Weitere IPs: neue SetEnvIf-Zeile mit TNET_ADMIN=1 ergänzen.
#
# Hinweis: www.gis-daten.ch (172.161.100.154) ist ein Reverse-Proxy.
# Apache sieht dessen IP, nicht die des Clients.
# → X-Forwarded-For wird zusätzlich geprüft.

# Direktzugriff (Remote_Addr = Client-IP)
SetEnvIf Remote_Addr "^127\.0\.0\.1$"         TNET_ADMIN=1
SetEnvIf Remote_Addr "^::1$"                   TNET_ADMIN=1
SetEnvIf Remote_Addr "^193\.135\.153\.250$"    TNET_ADMIN=1
SetEnvIf Remote_Addr "^193\.135\.153\.10$"     TNET_ADMIN=1
SetEnvIf Remote_Addr "^84\.241\.67\.175$"      TNET_ADMIN=1
SetEnvIf Remote_Addr "^10\.10\.5\.36$"          TNET_ADMIN=1
SetEnvIf Remote_Addr "^10\.203\.18\.133$"       TNET_ADMIN=1
SetEnvIf Remote_Addr "^10\.203\."                TNET_ADMIN=1

# Über Reverse-Proxy (X-Forwarded-For enthält echte Client-IP)
SetEnvIf X-Forwarded-For "84\.241\.67\.175"    TNET_ADMIN=1
SetEnvIf X-Forwarded-For "193\.135\.153\.10"   TNET_ADMIN=1
SetEnvIf X-Forwarded-For "10\.10\.5\.36"        TNET_ADMIN=1
SetEnvIf X-Forwarded-For "10\.203\.18\.133"     TNET_ADMIN=1
SetEnvIf X-Forwarded-For "10\.203\."             TNET_ADMIN=1

# --- Phase 1: SLM Admin-Seiten (HTML) ---
<FilesMatch "^(ags-import|slm|tree-builder|dev-test|tree-test)\.html$">
    Require env TNET_ADMIN
</FilesMatch>

# --- Phase 2: Schreibende / Admin PHP-Endpoints ---
<FilesMatch "^(admin|migrate|_migrate_ags_import|treebuilder-api)\.php$">
    Require env TNET_ADMIN
</FilesMatch>

# --- Phase 2b: Cache-Management (POST = clear) ---
<FilesMatch "^cache\.php$">
    <If "%{REQUEST_METHOD} == 'POST'">
        Require env TNET_ADMIN
    </If>
    <Else>
        Require all granted
    </Else>
</FilesMatch>

Options +FollowSymLinks -MultiViews
RewriteEngine On
RewriteBase /maps/tnet/api/v1/

# Wenn die angeforderte Datei/Ordner existiert → nichts tun
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# layers, basemaps, bookmarks, info, cache, server-check → .php anhängen
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.php [L,QSA]
